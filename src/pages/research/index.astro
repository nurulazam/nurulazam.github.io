---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { getCollection } from "astro:content";

// Phase 1: drafts included (clearly badged) so the example renders. Switch to
// `(await getCollection("research", ({ data }) => !data.draft))` for launch.
const entries = (await getCollection("research")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Chemical-formula display: digits → unicode subscripts (NiTe2 → NiTe₂).
const sub = (s: string) => s.replace(/[0-9]/g, (d) => "₀₁₂₃₄₅₆₇₈₉"[Number(d)]);

type Entry = (typeof entries)[number];

// One source of entries, grouped two ways. An entry with several tags on an
// axis appears under each of them — that is the dual-axis browse.
function groupBy(axis: "material" | "physics") {
  const map = new Map<string, Entry[]>();
  for (const e of entries) {
    for (const key of e.data[axis]) {
      const arr = map.get(key) ?? [];
      arr.push(e);
      map.set(key, arr);
    }
  }
  return [...map.entries()]
    .sort((a, b) => b[1].length - a[1].length || a[0].localeCompare(b[0]))
    .map(([key, items]) => ({
      key,
      label: axis === "material" ? sub(key) : key,
      entries: items,
    }));
}

const views = [
  { axis: "material" as const, label: "By material", groups: groupBy("material") },
  { axis: "physics" as const, label: "By physics", groups: groupBy("physics") },
];
---
<BaseLayout title="Research" description="Quantum-materials research, browsable by material or by physics.">
  <div class="container research">
    <Breadcrumbs crumbs={[{ label: "Home", href: "/" }, { label: "Research" }]} />

    <header class="research__head">
      <h1>Research</h1>
      <p class="lede">
        The same body of work, two ways in — browse <strong>by material</strong>
        or <strong>by physics</strong>.
      </p>
    </header>

    {entries.length > 0 ? (
      <>
        {/* Single toggle — hidden until JS upgrades it, so no dead control without JS. */}
        <div class="axis-toggle" role="group" aria-label="Browse research by" hidden>
          {views.map((v) => (
            <button
              type="button"
              class="axis-btn"
              data-axis={v.axis}
              aria-controls={`panel-${v.axis}`}
              aria-pressed={v.axis === "material" ? "true" : "false"}
            >
              {v.label}
            </button>
          ))}
        </div>

        {views.map((view) => (
          <section
            class="axis-panel"
            id={`panel-${view.axis}`}
            data-axis={view.axis}
            aria-label={`Research ${view.label.toLowerCase()}`}
            hidden={view.axis !== "material"}
          >
            {view.groups.map((group) => (
              <section class="group">
                <h2 class="group__title">
                  <span class="group__name">{group.label}</span>
                  <span class="group__count ui">{group.entries.length}</span>
                </h2>
                <ol class="research-grid">
                  {group.entries.map((entry) => (
                    <li class="card">
                      <div class="card__illo">
                        {entry.data.cover ? (
                          <img src={entry.data.cover} alt={entry.data.coverAlt ?? ""} loading="lazy" />
                        ) : (
                          <span class="card__illo-ph lattice-bg" aria-hidden="true">
                            <span class="ui">Illustration</span>
                          </span>
                        )}
                      </div>
                      <div class="card__body">
                        <div class="card__badges">
                          {entry.data.draft && <span class="badge">Draft</span>}
                          {entry.data.status === "in-progress" && (
                            <span class="badge badge--soft">In progress</span>
                          )}
                        </div>
                        <h3 class="card__title">
                          <a href={`/research/${entry.id}/`}>{entry.data.title}</a>
                        </h3>
                        <p class="card__desc">{entry.data.description}</p>
                        <ul class="card__tags" aria-label="Topics">
                          {entry.data.material.map((m) => (
                            <li class="tag tag--mat">{sub(m)}</li>
                          ))}
                          {entry.data.physics.map((p) => (
                            <li class="tag tag--phys">{p}</li>
                          ))}
                        </ul>
                      </div>
                    </li>
                  ))}
                </ol>
              </section>
            ))}
          </section>
        ))}
      </>
    ) : (
      <p class="empty ui">No research entries published yet — check back soon.</p>
    )}

    <p class="sr-only" role="status" aria-live="polite" id="axis-status"></p>
  </div>
</BaseLayout>

<style>
  .research { padding-block: var(--space-xl); }
  .research__head { max-width: var(--measure); margin-block: var(--space-m) var(--space-l); }
  .research__head h1 { margin-top: var(--space-2xs); }
  .lede { font-size: var(--step-1); color: var(--ink-soft); margin: 0; }
  .lede strong { color: var(--ink); font-weight: 600; }

  /* ── Single toggle (segmented control) ── */
  .axis-toggle {
    display: inline-flex;
    gap: var(--space-3xs);
    padding: var(--space-3xs);
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: 99px;
    margin-bottom: var(--space-xl);
  }
  .axis-btn {
    font-family: var(--font-ui);
    font-size: var(--step--1);
    color: var(--ink-soft);
    background: none;
    border: none;
    border-radius: 99px;
    padding: var(--space-2xs) var(--space-m);
    min-height: 44px;
    cursor: pointer;
    transition: color var(--transition-base), background var(--transition-base);
  }
  .axis-btn:hover[aria-pressed="false"] { color: var(--ink); }
  .axis-btn[aria-pressed="true"] { color: var(--bg); background: var(--accent); }

  /* ── Groups ── */
  .group { margin-bottom: var(--space-xl); }
  .group:last-child { margin-bottom: 0; }
  .group__title {
    display: flex;
    align-items: baseline;
    gap: var(--space-s);
    font-size: var(--step-2);
    padding-bottom: var(--space-2xs);
    margin-bottom: var(--space-l);
    border-bottom: 1px solid var(--rule);
  }
  .group__count { font-size: var(--step--1); color: var(--ink-soft); font-weight: 400; }

  /* ── Card grid ── */
  .research-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-l);
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) { .research-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 980px) { .research-grid { grid-template-columns: repeat(3, 1fr); } }

  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color var(--transition-base);
  }
  .card:hover { border-color: var(--ink-soft); }

  /* Illustration slot */
  .card__illo { aspect-ratio: 16 / 10; background: var(--bg); }
  .card__illo img { width: 100%; height: 100%; object-fit: cover; }
  .card__illo-ph { display: grid; place-items: center; width: 100%; height: 100%; }
  .card__illo-ph .ui {
    font-size: var(--step--1);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .card__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    padding: var(--space-m);
  }
  .card__badges { display: flex; flex-wrap: wrap; gap: var(--space-2xs); }
  .card__title { font-size: var(--step-1); margin: var(--space-3xs) 0 0; }
  .card__title a {
    color: var(--ink);
    text-decoration: none;
    transition: color var(--transition-base);
  }
  /* Stretched link: whole card clickable, single link in the a11y tree. */
  .card__title a::after { content: ""; position: absolute; inset: 0; }
  .card:hover .card__title a { color: var(--accent-ink); }
  .card__desc { color: var(--ink-soft); margin: 0; font-size: var(--step-0); }

  .card__tags {
    list-style: none;
    margin: var(--space-2xs) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
  }
  .tag {
    font-family: var(--font-ui);
    font-size: var(--step--1);
    padding: var(--space-3xs) var(--space-xs);
    border-radius: 99px;
    line-height: 1.5;
  }
  .tag--mat { background: var(--accent-wash); color: var(--accent-ink); }
  .tag--phys { border: 1px solid var(--rule); color: var(--ink-soft); }

  .badge {
    font-family: var(--font-ui);
    font-size: var(--step--1);
    font-weight: 500;
    padding: 1px var(--space-xs);
    background: var(--accent-wash);
    color: var(--accent-ink);
    border-radius: var(--radius);
    line-height: 1.6;
  }
  .badge--soft { background: transparent; border: 1px solid var(--rule); color: var(--ink-soft); }

  .empty { color: var(--ink-soft); font-style: italic; padding-block: var(--space-m); }

  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
  }
</style>

<script>
  // Progressive enhancement: reveal the toggle and switch between the two
  // already-rendered panels. Without JS the "By material" panel stands alone.
  const toggle = document.querySelector<HTMLElement>(".axis-toggle");
  const panels = Array.from(document.querySelectorAll<HTMLElement>(".axis-panel"));

  if (toggle && panels.length) {
    const buttons = Array.from(toggle.querySelectorAll<HTMLButtonElement>(".axis-btn"));
    const status = document.getElementById("axis-status");
    const known = new Set(buttons.map((b) => b.dataset.axis));

    function show(axis: string, announce: boolean) {
      panels.forEach((p) => { p.hidden = p.dataset.axis !== axis; });
      buttons.forEach((b) => b.setAttribute("aria-pressed", String(b.dataset.axis === axis)));
      if (announce && status) status.textContent = `Browsing research by ${axis}.`;
    }

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const axis = btn.dataset.axis ?? "material";
        show(axis, true);
        history.replaceState(null, "", axis === "material" ? location.pathname : `#by=${axis}`);
      });
    });

    toggle.hidden = false;

    // Honour a #by=physics deep link.
    let initial = "material";
    if (location.hash.startsWith("#by=")) {
      const axis = decodeURIComponent(location.hash.slice(4));
      if (known.has(axis)) initial = axis;
    }
    if (initial !== "material") show(initial, false);
  }
</script>
