---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";

// ── Instrument / facility map geometry (computed once, emitted as static SVG) ──
const CX = 440;
const CY = 250;
const RADIUS = 170;
const rad = (deg: number) => (deg * Math.PI) / 180;

// Six techniques arranged around the central sample. RHEED is in-situ during
// growth, so it sits with synthesis; the rest are characterisation.
const techniques = [
  { id: "mbe", label: "MBE", group: "Synthesis", angle: -90 },
  { id: "rheed", label: "RHEED", group: "Synthesis", angle: -30 },
  { id: "momentum", label: "Momentum Microscopy", group: "Characterisation", angle: 30 },
  { id: "raman", label: "Cryo-Raman", group: "Characterisation", angle: 90 },
  { id: "afm", label: "AFM / MFM", group: "Characterisation", angle: 150 },
  { id: "nv", label: "NV Magnetometry", group: "Characterisation", angle: 210 },
] as const;

const nodes = techniques.map((t) => {
  const a = rad(t.angle);
  const nx = CX + RADIUS * Math.cos(a);
  const ny = CY + RADIUS * Math.sin(a);
  const lx = CX + (RADIUS + 46) * Math.cos(a);
  const ly = CY + (RADIUS + 46) * Math.sin(a);
  const anchor = nx < CX - 8 ? "end" : nx > CX + 8 ? "start" : "middle";
  return { ...t, nx, ny, lx, ly, anchor };
});

// Central hexagonal-lattice sample motif (one vertex left as a vacancy).
const hexR = 50;
const hexPts = Array.from({ length: 6 }, (_, i) => {
  const a = rad(-90 + i * 60);
  return [CX + hexR * Math.cos(a), CY + hexR * Math.sin(a)] as const;
});
const hexPath = hexPts.map((p) => p.join(",")).join(" ");

// Minimal per-technique glyphs (centred on 0,0). currentColor is inherited from
// the styled <g> wrapper, so colours stay token-driven.
const glyph = (id: string): string => {
  const s = 'stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"';
  switch (id) {
    case "mbe": // molecular beams onto a substrate bar
      return `<g ${s}><line x1="-15" y1="-9" x2="15" y2="-9"/><line x1="-9" y1="10" x2="-9" y2="-5"/><line x1="0" y1="12" x2="0" y2="-5"/><line x1="9" y1="10" x2="9" y2="-5"/></g>`;
    case "rheed": // diffraction streaks above a screen line
      return `<g ${s}><line x1="-13" y1="12" x2="13" y2="12"/><line x1="-10" y1="8" x2="-10" y2="-10" stroke-dasharray="2 3"/><line x1="0" y1="8" x2="0" y2="-13" stroke-dasharray="2 3"/><line x1="10" y1="8" x2="10" y2="-10" stroke-dasharray="2 3"/></g>`;
    case "momentum": // band dispersion in k-space
      return `<g ${s}><line x1="-15" y1="12" x2="15" y2="12"/><path d="M-13 -10 Q0 16 13 -10"/></g>`;
    case "raman": // spectrum with two peaks
      return `<polyline ${s} points="-15,11 -9,11 -6,-9 -3,11 4,11 7,-3 10,11 15,11"/>`;
    case "afm": // cantilever + tip over a surface
      return `<g ${s}><line x1="-15" y1="12" x2="15" y2="12"/><line x1="2" y1="-11" x2="13" y2="-13"/><path d="M-3 -10 L5 2 L-7 2 Z" fill="currentColor" stroke="none"/></g>`;
    case "nv": // NV centre: diamond + spin arrow
      return `<g ${s}><rect x="-9" y="-9" width="18" height="18" transform="rotate(45)"/><line x1="0" y1="9" x2="0" y2="-9"/><path d="M-3 -5 L0 -10 L3 -5"/></g>`;
    default:
      return "";
  }
};

const synthesis = techniques.filter((t) => t.group === "Synthesis");
const characterisation = techniques.filter((t) => t.group === "Characterisation");
---
<BaseLayout title="About" description="About Dr. Nurul Azam — quantum-materials researcher bridging synthesis, characterisation, and scientific software.">
  <div class="container about">
    <Breadcrumbs crumbs={[{ label: "Home", href: "/" }, { label: "About" }]} />

    <header class="about__head">
      <h1>About</h1>
      <p class="lede">
        Where synthesis, characterisation, and machine intelligence form one recursive loop.
      </p>
    </header>

    <!-- PLACEHOLDER bio — replace with a real narrative. Do not invent facts. -->
    <div class="prose about__bio">
      <p>I am a quantum-materials researcher working where atomic-scale synthesis, advanced characterisation, and machine intelligence meet. My work follows one recursive loop: synthesise a material, probe its structure and behaviour, and feed what I learn back into the next growth, so the physics and the tools that reveal it advance together.</p>
      <p>I earned my Ph.D. in Electrical & Computer Engineering at Auburn University, Auburn, Alabama. My doctoral work pioneered laser-based synthesis of two-dimensional transition metal dichalcogenides, growing high-quality monolayers (MoS₂, MoSe₂, WSe₂, WS₂, WTe₂) with a single-step laser method for atomically precise vacancy tuning. I also demonstrated the first time-resolved growth of 2D TMDCs, reaching a record growth rate of 100 μm/s within a 10 ms growth window on non-catalytic substrates. I now work in the Department of Physics and the Quantum Materials and Sensing Institute at Northeastern University, Massachusetts, using molecular beam epitaxy, momentum microscopy (an ARPES-like probe), cryo-state Raman, and other state-of-the-art instruments to study topological and magnetic quantum materials.</p>
      <p>My current focus is the epitaxial growth and momentum-resolved electronic structure of altermagnetic, ferromagnetic, type-II Dirac semimetal, and superconducting quantum materials, alongside a swarm of AI- and machine-learning-driven software tools I am building to accelerate discovery.</p>
    </div>

    <p class="about__cv">
      <a class="cv-link ui" href="/cv.pdf" download>Download CV (PDF)</a>
      <span class="cv-note ui"  <code>public/cv.pdf</code>.</span>
    </p>

    <!-- Instrument / facility map -->
    <section class="imap-section" aria-labelledby="imap-hd">
      <h2 id="imap-hd">Instruments &amp; facilities</h2>
      <p class="imap-intro">
        The tools I use to grow and study quantum materials — synthesis on one
        side, characterisation on the other, the sample at the centre.
      </p>

      <figure class="imap-figure">
        <svg
          class="imap"
          viewBox="0 0 880 510"
          role="img"
          aria-label="Instrument and facility map: a central quantum-material sample studied with synthesis tools (MBE, RHEED) and characterisation tools (momentum microscopy, cryo-Raman, AFM/MFM, NV magnetometry)."
        >
          <title>Instrument and facility map</title>

          <!-- connecting lines (drawn first, under the nodes) -->
          {nodes.map((n) => (
            <line class="imap__link" x1={CX} y1={CY} x2={n.nx} y2={n.ny} />
          ))}

          <!-- central hexagonal-lattice sample with a vacancy -->
          <polygon class="imap__hex" points={hexPath} />
          {hexPts.map((p, i) =>
            i === 1 ? (
              <circle class="imap__vac" cx={p[0]} cy={p[1]} r="5" />
            ) : (
              <circle class="imap__atom" cx={p[0]} cy={p[1]} r="4" />
            )
          )}
          <circle class="imap__atom" cx={CX} cy={CY} r="4" />
          <text class="imap__sample" x={CX} y={CY + hexR + 18} text-anchor="middle">Sample</text>

          <!-- technique nodes -->
          {nodes.map((n) => (
            <g class="imap__nodewrap">
              <circle class="imap__node" cx={n.nx} cy={n.ny} r="27" />
              <g class="imap__glyph" transform={`translate(${n.nx} ${n.ny})`} set:html={glyph(n.id)} />
              <text
                class="imap__label"
                x={n.lx}
                y={n.ly}
                text-anchor={n.anchor}
                dominant-baseline="middle"
              >{n.label}</text>
            </g>
          ))}
        </svg>
        <figcaption class="imap-caption ui">
          A schematic map, not to scale.
        </figcaption>
      </figure>

      <!-- Text legend: the same information, fully accessible and selectable. -->
      <div class="imap-legend">
        <div>
          <p class="eyebrow">Synthesis</p>
          <ul>{synthesis.map((t) => <li>{t.label}</li>)}</ul>
        </div>
        <div>
          <p class="eyebrow">Characterisation</p>
          <ul>{characterisation.map((t) => <li>{t.label}</li>)}</ul>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .about { padding-block: var(--space-xl); }
  .about__head { max-width: var(--measure); margin-block: var(--space-m) var(--space-l); }
  .about__head h1 { margin-top: var(--space-2xs); }
  .lede { font-size: var(--step-1); color: var(--ink-soft); margin: 0; }

  .about__bio { margin-bottom: var(--space-l); }

  /* ── CV download (secondary action, not the primary CTA) ── */
  .about__cv {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-s);
    margin-bottom: var(--space-2xl);
  }
  .cv-link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: var(--space-2xs) var(--space-m);
    border: 1px solid var(--ink-soft);
    border-radius: var(--radius);
    color: var(--ink);
    text-decoration: none;
    font-size: var(--step--1);
    transition: border-color var(--transition-base), color var(--transition-base);
  }
  .cv-link:hover { border-color: var(--accent); color: var(--accent-ink); }
  .cv-note { font-size: var(--step--1); color: var(--ink-soft); }

  /* ── Instrument map ── */
  .imap-section { border-top: 1px solid var(--rule); padding-top: var(--space-xl); }
  .imap-intro { max-width: var(--measure); color: var(--ink-soft); margin: 0 0 var(--space-l); }

  .imap-figure { max-width: 660px; margin: 0 auto; }
  .imap { width: 100%; height: auto; display: block; }
  .imap-caption {
    text-align: center;
    font-size: var(--step--1);
    color: var(--ink-soft);
    margin-top: var(--space-2xs);
  }

  .imap__link { stroke: var(--rule); stroke-width: 2; }
  .imap__hex { fill: var(--accent-wash); stroke: var(--accent); stroke-width: 2; }
  .imap__atom { fill: var(--accent); }
  .imap__vac { fill: none; stroke: var(--accent); stroke-width: 1.5; stroke-dasharray: 2 3; }
  .imap__sample {
    font-family: var(--font-ui);
    font-size: 15px;
    fill: var(--ink-soft);
    letter-spacing: 0.06em;
  }
  .imap__node { fill: var(--surface); stroke: var(--rule); stroke-width: 2; }
  .imap__glyph { color: var(--ink); }
  .imap__label {
    font-family: var(--font-ui);
    font-size: 16px;
    fill: var(--ink);
  }

  /* ── Text legend ── */
  .imap-legend {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-l);
    max-width: var(--measure);
    margin: var(--space-xl) auto 0;
  }
  .imap-legend ul { list-style: none; margin: var(--space-2xs) 0 0; padding: 0; }
  .imap-legend li {
    font-family: var(--font-ui);
    font-size: var(--step-0);
    padding-block: var(--space-3xs);
    color: var(--ink);
  }
  @media (min-width: 560px) {
    .imap-legend { grid-template-columns: 1fr 1fr; }
  }
</style>
