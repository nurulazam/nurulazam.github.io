---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { SOCIALS } from "../../config/site";
import pubsData from "../../data/publications.json";

type Pub = {
  year: number;
  authors: string;
  title: string;
  venue: string;
  doi: string;
};
const data = pubsData as { note?: string; selected: Pub[] };

// Group strictly by what's in the data file — newest year first. No invented
// entries, DOIs, or citation counts (see CLAUDE.md rule 8).
const byYear = new Map<number, Pub[]>();
for (const p of [...data.selected].sort((a, b) => b.year - a.year)) {
  const arr = byYear.get(p.year) ?? [];
  arr.push(p);
  byYear.set(p.year, arr);
}
const years = [...byYear.keys()].sort((a, b) => b - a);

// Full record lives on Scholar / ORCID — URLs come from site.ts (single source).
const scholar = SOCIALS.find((s) => s.label === "Google Scholar");
const orcid = SOCIALS.find((s) => s.label === "ORCID");

// Emphasise the author's own name in each author list (display only).
const OWNER = "Azam";
const authorParts = (authors: string) => authors.split(new RegExp(`(${OWNER})`));
---
<BaseLayout title="Publications" description="Selected peer-reviewed publications by Dr. Nurul Azam.">
  <div class="container publications">
    <Breadcrumbs crumbs={[{ label: "Home", href: "/" }, { label: "Publications" }]} />

    <header class="publications__head">
      <h1>Publications</h1>
      <p class="lede">
        Selected peer-reviewed work on the synthesis and characterisation of
        quantum materials.
      </p>
      {(scholar || orcid) && (
        <p class="pub-links ui">
          Full record:{" "}
          {scholar && (
            <a href={scholar.href} target="_blank" rel="noopener noreferrer">Google Scholar ↗</a>
          )}
          {scholar && orcid && <span aria-hidden="true"> · </span>}
          {orcid && (
            <a href={orcid.href} target="_blank" rel="noopener noreferrer">ORCID ↗</a>
          )}
        </p>
      )}
    </header>

    {years.length > 0 ? (
      years.map((year) => (
        <section class="year-group">
          <h2 class="year-group__year">{year}</h2>
          <ol class="pub-list">
            {byYear.get(year)!.map((p) => (
              <li class="pub">
                <h3 class="pub__title">{p.title}</h3>
                <p class="pub__authors">
                  {authorParts(p.authors).map((part, i) =>
                    i % 2 === 1 ? <strong>{part}</strong> : part
                  )}
                </p>
                <p class="pub__venue ui"><em>{p.venue}</em></p>
                {p.doi && (
                  <a
                    class="pub__doi ui"
                    href={`https://doi.org/${p.doi}`}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    doi.org/{p.doi} ↗
                  </a>
                )}
              </li>
            ))}
          </ol>
        </section>
      ))
    ) : (
      <p class="empty ui">Publication list coming soon.</p>
    )}

    {data.note && <p class="pub-note ui">{data.note}</p>}
  </div>
</BaseLayout>

<style>
  .publications { padding-block: var(--space-xl); }
  .publications__head { max-width: var(--measure); margin-block: var(--space-m) var(--space-xl); }
  .publications__head h1 { margin-top: var(--space-2xs); }
  .lede { font-size: var(--step-1); color: var(--ink-soft); margin: 0 0 var(--space-s); }
  .pub-links { font-size: var(--step--1); color: var(--ink-soft); margin: 0; }
  .pub-links a { color: var(--accent-ink); text-decoration: none; }
  .pub-links a:hover { text-decoration: underline; }

  /* ── Year groups ── */
  .year-group { margin-bottom: var(--space-2xl); }
  .year-group:last-of-type { margin-bottom: var(--space-l); }
  .year-group__year {
    font-size: var(--step-2);
    color: var(--accent-ink);
    padding-bottom: var(--space-2xs);
    margin-bottom: var(--space-m);
    border-bottom: 1px solid var(--rule);
  }

  /* ── Publication entries ── */
  .pub-list { list-style: none; margin: 0; padding: 0; }
  .pub {
    max-width: var(--measure);
    padding-block: var(--space-m);
    border-top: 1px solid var(--rule);
  }
  .pub:first-child { border-top: none; padding-top: 0; }
  .pub__title {
    font-family: var(--font-body);
    font-size: var(--step-1);
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 var(--space-3xs);
  }
  .pub__authors { margin: 0 0 var(--space-3xs); color: var(--ink); font-size: var(--step-0); }
  .pub__authors strong { font-weight: 700; color: var(--accent-ink); }
  .pub__venue { margin: 0; font-size: var(--step--1); color: var(--ink-soft); }
  .pub__doi {
    display: inline-block;
    margin-top: var(--space-2xs);
    font-size: var(--step--1);
    color: var(--accent-ink);
    text-decoration: none;
  }
  .pub__doi:hover { text-decoration: underline; }

  .pub-note {
    max-width: var(--measure);
    font-size: var(--step--1);
    color: var(--ink-soft);
    font-style: italic;
    padding-top: var(--space-m);
    border-top: 1px solid var(--rule);
  }
  .empty { color: var(--ink-soft); font-style: italic; padding-block: var(--space-m); }
</style>
