---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { WRITING_CATEGORIES } from "../../config/site";

// Link to the evolving "Mentoring Philosophy" thread via the writing index's
// #cat= filter. Category name comes from site.ts so it stays in sync.
const MENTORING = WRITING_CATEGORIES.find((c) => c === "Mentoring Philosophy") ?? "Mentoring Philosophy";
const philosophyHref = `/writing/#cat=${encodeURIComponent(MENTORING)}`;

// PLACEHOLDER records — replace with the real teaching/mentoring history.
// No invented facts: rows are clearly marked until real content is added.
const teaching = [
  { role: "PLACEHOLDER — Course or teaching role", org: "PLACEHOLDER — Institution", term: "PLACEHOLDER — Term" },
  { role: "PLACEHOLDER — Course or teaching role", org: "PLACEHOLDER — Institution", term: "PLACEHOLDER — Term" },
];

const mentoring = [
  { role: "PLACEHOLDER — Mentee level (e.g. undergraduate / graduate)", focus: "PLACEHOLDER — Project focus" },
  { role: "PLACEHOLDER — Mentee level", focus: "PLACEHOLDER — Project focus" },
];
---
<BaseLayout title="Teaching & Mentoring" description="Teaching record, research mentoring, and an evolving philosophy on mentorship and technology.">
  <div class="container teaching">
    <Breadcrumbs crumbs={[{ label: "Home", href: "/" }, { label: "Teaching" }]} />

    <header class="teaching__head">
      <h1>Teaching &amp; Mentoring</h1>
      <p class="lede">
        Training students in the craft of growing and measuring quantum
        materials — and in the scientific software that supports the work.
      </p>
    </header>

    <section class="record" aria-labelledby="teaching-hd">
      <h2 id="teaching-hd" class="record__title">Teaching</h2>
      <ul class="entry-list">
        {teaching.map((t) => (
          <li class="entry">
            <p class="entry__role">{t.role}</p>
            <p class="entry__meta ui">{t.org}<span aria-hidden="true"> · </span>{t.term}</p>
          </li>
        ))}
      </ul>
    </section>

    <section class="record" aria-labelledby="mentoring-hd">
      <h2 id="mentoring-hd" class="record__title">Mentoring</h2>
      <ul class="entry-list">
        {mentoring.map((m) => (
          <li class="entry">
            <p class="entry__role">{m.role}</p>
            <p class="entry__meta ui">{m.focus}</p>
          </li>
        ))}
      </ul>
    </section>

    <!-- The philosophy thread — reachable as a writing category. -->
    <section class="philosophy" aria-labelledby="philosophy-hd">
      <p class="eyebrow">Ongoing thread</p>
      <h2 id="philosophy-hd" class="philosophy__title">Mentoring Philosophy</h2>
      <p class="philosophy__body">
        An evolving set of notes on mentorship and technology — how I think about
        teaching, supervising, and building people up alongside the science.
      </p>
      <a class="philosophy__link ui" href={philosophyHref}>
        Read the Mentoring Philosophy thread →
      </a>
    </section>
  </div>
</BaseLayout>

<style>
  .teaching { padding-block: var(--space-xl); }
  .teaching__head { max-width: var(--measure); margin-block: var(--space-m) var(--space-xl); }
  .teaching__head h1 { margin-top: var(--space-2xs); }
  .lede { font-size: var(--step-1); color: var(--ink-soft); margin: 0; }

  /* ── Record sections ── */
  .record { max-width: var(--measure); margin-bottom: var(--space-2xl); }
  .record__title {
    font-size: var(--step-2);
    padding-bottom: var(--space-2xs);
    margin-bottom: var(--space-m);
    border-bottom: 1px solid var(--rule);
  }
  .entry-list { list-style: none; margin: 0; padding: 0; }
  .entry { padding-block: var(--space-m); border-top: 1px solid var(--rule); }
  .entry:first-child { border-top: none; padding-top: 0; }
  .entry__role { margin: 0 0 var(--space-3xs); font-size: var(--step-1); }
  .entry__meta { margin: 0; font-size: var(--step--1); color: var(--ink-soft); }

  /* ── Mentoring Philosophy callout ── */
  .philosophy {
    max-width: var(--measure);
    padding: var(--space-l);
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: var(--radius-lg);
  }
  .philosophy__title { font-size: var(--step-2); margin: var(--space-2xs) 0 var(--space-s); }
  .philosophy__body { color: var(--ink-soft); margin: 0 0 var(--space-m); }
  .philosophy__link {
    font-size: var(--step-0);
    color: var(--accent-ink);
    text-decoration: none;
    font-weight: 500;
  }
  .philosophy__link:hover { text-decoration: underline; }
</style>
