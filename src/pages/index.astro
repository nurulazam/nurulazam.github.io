---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroAnimation from "../components/HeroAnimation.astro";
import { SITE, PRIMARY_CTA } from "../config/site";
import { getCollection } from "astro:content";
import pubsData from "../data/publications.json";

// Home page previews include draft entries so placeholder sections stay visible
// until real content is added.
const allResearch = (await getCollection("research")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const allSoftware = (await getCollection("software")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const latestPosts = (await getCollection("writing"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const pubs = pubsData.selected;
const pubNote: string = (pubsData as { note: string; selected: typeof pubs }).note;

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short" });

const pillars = [
  {
    eyebrow: "Synthesis",
    title: "Quantum Materials Growth",
    body: "MBE and laser-assisted synthesis of 2D, magnetic, and topological materials — with fine control over vacancy concentration and crystal quality.",
  },
  {
    eyebrow: "Characterisation",
    title: "Spectroscopy & Momentum Microscopy",
    body: "Band structure, defect states, and ultrafast dynamics via momentum microscopy, cryo-Raman, RHEED, and NV magnetometry.",
  },
  {
    eyebrow: "Computation",
    title: "Scientific Software & AI",
    body: "Instrument control, data pipelines, and AI-guided optimisation workflows that close the loop between synthesis and characterisation.",
  },
];
---

<BaseLayout>

  <!-- ① Hero identity + animation slot ------------------------------------ -->
  <section class="hero container lattice-bg">
    <p class="eyebrow">Quantum materials · {SITE.author}</p>
    <h1 class="hero__title">{SITE.identity}</h1>
    <HeroAnimation />
  </section>

  <!-- ② Three identity cards --------------------------------------------- -->
  <section class="pillars container" aria-label="Research identity — three pillars">
    {pillars.map((p) => (
      <article class="pillar">
        <p class="eyebrow">{p.eyebrow}</p>
        <h2 class="pillar__title">{p.title}</h2>
        <p class="pillar__body">{p.body}</p>
      </article>
    ))}
  </section>

  <!-- ③ Featured research story ------------------------------------------ -->
  <section class="featured container" aria-label="Featured research">
    <header class="section-head">
      <p class="eyebrow">Featured research</p>
      <a class="section-head__link ui" href="/research/">All research →</a>
    </header>

    {allResearch[0] ? (
      <article class="featured-card">
        <div class="featured-card__top">
          {allResearch[0].data.material.length > 0 && (
            <span class="eyebrow">{allResearch[0].data.material.join(" · ")}</span>
          )}
          {allResearch[0].data.draft && <span class="badge">Placeholder</span>}
        </div>
        <h2 class="featured-card__title">{allResearch[0].data.title}</h2>
        <p class="featured-card__desc">{allResearch[0].data.description}</p>
        {allResearch[0].data.physics.length > 0 && (
          <ul class="tag-list" aria-label="Physics topics">
            {allResearch[0].data.physics.map((t) => <li class="tag">{t}</li>)}
          </ul>
        )}
      </article>
    ) : (
      <article class="featured-card featured-card--stub">
        <p class="placeholder ui">
          PLACEHOLDER — add a published entry to <code>src/content/research/</code>
        </p>
        <h2 class="featured-card__title">Featured research story title</h2>
        <p class="featured-card__desc">
          One paragraph describing the key finding and its significance.
          Replace with real, published work only.
        </p>
      </article>
    )}
  </section>

  <!-- ④ Selected publications -------------------------------------------- -->
  <section class="publications container" aria-label="Selected publications">
    <header class="section-head">
      <p class="eyebrow">Selected publications</p>
      <a class="section-head__link ui" href="/publications/">All publications →</a>
    </header>

    <ol class="pub-list">
      {pubs.map((pub) => (
        <li class="pub">
          <span class="pub__year ui">{pub.year}</span>
          <div class="pub__body">
            <p class="pub__title">{pub.title}</p>
            <p class="pub__meta ui">
              {pub.authors}&ensp;·&ensp;<em>{pub.venue}</em>
            </p>
            {pub.doi && (
              <a
                class="pub__doi ui"
                href={`https://doi.org/${pub.doi}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                DOI →
              </a>
            )}
          </div>
        </li>
      ))}
    </ol>

    {pubNote && <p class="pub-note ui">{pubNote}</p>}
  </section>

  <!-- ⑤ Scientific software & tools preview ----------------------------- -->
  <section class="software-preview container" aria-labelledby="software-hd">
    <h2 id="software-hd" class="sr-only">Scientific software and tools</h2>
    <header class="section-head">
      <p class="eyebrow">Scientific software &amp; tools</p>
      <a class="section-head__link ui" href="/software/">All projects →</a>
    </header>

    {allSoftware.length > 0 ? (
      <ul class="software-grid">
        {allSoftware.map((item) => (
          <li class="software-card">
            <div class="software-card__top">
              <p class="eyebrow">{item.data.kind}</p>
              {item.data.draft && <span class="badge">Placeholder</span>}
            </div>
            <h3 class="software-card__title">{item.data.title}</h3>
            <p class="software-card__desc">{item.data.description}</p>
            {item.data.stack.length > 0 && (
              <ul class="tag-list" aria-label="Tech stack">
                {item.data.stack.map((t) => <li class="tag">{t}</li>)}
              </ul>
            )}
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty-note ui">
        PLACEHOLDER — add software entries to <code>src/content/software/</code>.
      </p>
    )}
  </section>

  <!-- ⑥ Latest writing (from collection) --------------------------------- -->
  <section class="writing container" aria-labelledby="writing-hd">
    <header class="section-head">
      <h2 id="writing-hd">Latest writing</h2>
      <a class="section-head__link ui" href="/writing/">All writing →</a>
    </header>

    {latestPosts.length > 0 ? (
      <ul class="post-list">
        {latestPosts.map((post) => (
          <li>
            <a class="post-item" href={`/writing/${post.id}/`}>
              <span class="post-item__cat eyebrow">{post.data.category}</span>
              <span class="post-item__title">{post.data.title}</span>
              <time class="ui" datetime={post.data.date.toISOString()}>
                {fmt(post.data.date)}
              </time>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty-note ui">
        PLACEHOLDER — add writing entries to <code>src/content/writing/</code>.
      </p>
    )}
  </section>

  <!-- ⑦ Contact CTA — the ONE primary CTA on the entire site ------------ -->
  <section class="contact-cta container" aria-label="Get in touch">
    <div class="contact-cta__inner">
      <p class="eyebrow">Collaboration</p>
      <h2 class="contact-cta__title">Interested in working together?</h2>
      <!-- PLACEHOLDER: replace with your own invitation copy -->
      <p class="contact-cta__body">
        Whether you are looking to synthesise a specific 2D or magnetic material,
        need momentum-microscopy or Raman expertise, or want to collaborate on
        scientific software — get in touch.
      </p>
      <a class="btn-primary" href={PRIMARY_CTA.href}>{PRIMARY_CTA.label}</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Shared section chrome ─────────────────────────────────────────────── */
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-m);
    flex-wrap: wrap;
    margin-bottom: var(--space-m);
  }
  .section-head h2 {
    margin: 0;
    font-size: var(--step-2);
  }
  .section-head__link {
    font-size: var(--step--1);
    color: var(--ink-soft);
    text-decoration: none;
    flex-shrink: 0;
    transition: color var(--transition-base);
  }
  .section-head__link:hover { color: var(--accent-ink); }

  /* ── Shared utilities ──────────────────────────────────────────────────── */
  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0;
    margin: -1px; overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }

  .badge {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: var(--step--1);
    font-weight: 500;
    padding: 1px var(--space-xs);
    background: var(--accent-wash);
    color: var(--accent-ink);
    border-radius: var(--radius);
    line-height: 1.6;
  }

  .tag-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-wrap: wrap; gap: var(--space-2xs);
  }
  .tag {
    font-family: var(--font-ui);
    font-size: var(--step--1);
    padding: var(--space-3xs) var(--space-xs);
    border: 1px solid var(--rule);
    border-radius: 99px;
    color: var(--ink-soft);
  }

  .placeholder { color: var(--ink-soft); font-size: var(--step--1); }

  .empty-note {
    color: var(--ink-soft);
    font-size: var(--step--1);
    font-style: italic;
    padding-block: var(--space-m);
  }

  /* ── ① Hero ────────────────────────────────────────────────────────────── */
  .hero {
    padding-block: var(--space-2xl) var(--space-xl);
  }
  .hero__title {
    max-width: 18ch;
    margin-top: var(--space-s);
  }

  /* ── ② Pillars ─────────────────────────────────────────────────────────── */
  .pillars {
    display: grid;
    gap: var(--space-m);
    grid-template-columns: 1fr;
    padding-block: var(--space-xl);
    border-top: 1px solid var(--rule);
  }
  .pillar {
    padding: var(--space-m);
    border: 1px solid var(--rule);
    border-radius: var(--radius-lg);
    background: var(--surface);
  }
  .pillar__title {
    font-size: var(--step-1);
    margin: var(--space-2xs) 0 var(--space-xs);
  }
  .pillar__body {
    color: var(--ink-soft);
    margin: 0;
  }

  /* ── ③ Featured research ───────────────────────────────────────────────── */
  .featured {
    padding-block: var(--space-xl);
    border-top: 1px solid var(--rule);
  }
  .featured-card {
    padding: var(--space-l);
    border: 1px solid var(--rule);
    border-radius: var(--radius-lg);
    background: var(--surface);
  }
  .featured-card--stub {
    border-style: dashed;
  }
  .featured-card__top {
    display: flex;
    align-items: center;
    gap: var(--space-s);
    margin-bottom: var(--space-xs);
  }
  .featured-card__title {
    font-size: var(--step-2);
    margin: 0 0 var(--space-s);
  }
  .featured-card__desc {
    color: var(--ink-soft);
    margin: 0 0 var(--space-m);
  }

  /* ── ④ Publications ────────────────────────────────────────────────────── */
  .publications {
    padding-block: var(--space-xl);
    border-top: 1px solid var(--rule);
  }
  .pub-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .pub {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: var(--space-s);
    padding-block: var(--space-m);
    border-bottom: 1px solid var(--rule);
    align-items: start;
  }
  .pub__year {
    color: var(--ink-soft);
    font-size: var(--step--1);
    padding-top: 0.15em;
    line-height: 1.5;
  }
  .pub__title {
    font-family: var(--font-body);
    font-size: var(--step-0);
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 var(--space-3xs);
  }
  .pub__meta {
    font-size: var(--step--1);
    color: var(--ink-soft);
    margin: 0;
  }
  .pub__doi {
    display: inline-block;
    font-size: var(--step--1);
    margin-top: var(--space-3xs);
    color: var(--accent-ink);
  }
  .pub-note {
    font-size: var(--step--1);
    color: var(--ink-soft);
    font-style: italic;
    margin-top: var(--space-s);
  }

  /* ── ⑤ Software preview ────────────────────────────────────────────────── */
  .software-preview {
    padding-block: var(--space-xl);
    border-top: 1px solid var(--rule);
  }
  .software-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-m);
    grid-template-columns: 1fr;
  }
  .software-card {
    padding: var(--space-m);
    border: 1px solid var(--rule);
    border-radius: var(--radius-lg);
    background: var(--surface);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  .software-card__top {
    display: flex;
    align-items: center;
    gap: var(--space-s);
  }
  .software-card__title {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 560;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .software-card__desc {
    color: var(--ink-soft);
    font-size: var(--step-0);
    flex: 1;
    margin: 0;
  }

  /* ── ⑥ Writing ─────────────────────────────────────────────────────────── */
  .writing {
    padding-block: var(--space-xl);
    border-top: 1px solid var(--rule);
  }
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .post-list li + li { border-top: 1px solid var(--rule); }
  .post-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: 0 var(--space-s);
    padding-block: var(--space-m);
    text-decoration: none;
    color: var(--ink);
    transition: color var(--transition-base);
  }
  .post-item:hover { color: var(--accent-ink); }
  .post-item__cat { color: var(--accent-ink); flex-shrink: 0; }
  .post-item:hover .post-item__cat { color: inherit; }
  .post-item__title {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 560;
    min-width: 0;
  }
  .post-item time {
    color: var(--ink-soft);
    font-size: var(--step--1);
    white-space: nowrap;
  }

  /* ── ⑦ Contact CTA ─────────────────────────────────────────────────────── */
  .contact-cta {
    padding-block: var(--space-2xl);
    border-top: 1px solid var(--rule);
  }
  .contact-cta__inner {
    max-width: 52ch;
    margin-inline: auto;
    text-align: center;
  }
  .contact-cta__title {
    font-size: var(--step-3);
    margin: var(--space-xs) 0 var(--space-s);
  }
  .contact-cta__body {
    color: var(--ink-soft);
    margin: 0 0 var(--space-l);
  }
  .btn-primary {
    display: inline-block;
    padding: var(--space-s) var(--space-l);
    background: var(--accent);
    color: var(--bg);
    font-family: var(--font-ui);
    font-size: var(--step-0);
    font-weight: 600;
    letter-spacing: 0.01em;
    text-decoration: none;
    border-radius: var(--radius);
    transition: opacity var(--transition-base);
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .btn-primary:hover { opacity: 0.88; }
  .btn-primary:focus-visible {
    outline: var(--focus);
    outline-offset: 3px;
  }

  /* ── Responsive ─────────────────────────────────────────────────────────── */

  /* ≥ 680px: pillars → 3-column */
  @media (min-width: 680px) {
    .pillars { grid-template-columns: repeat(3, 1fr); }
  }

  /* ≥ 640px: software → 2-column grid */
  @media (min-width: 640px) {
    .software-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ≥ 900px: software → 3-column grid */
  @media (min-width: 900px) {
    .software-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* < 560px: post-item collapses to stacked */
  @media (max-width: 559px) {
    .post-item {
      grid-template-columns: 1fr;
      gap: var(--space-3xs);
    }
    .post-item time { display: none; }
    .contact-cta__inner { text-align: left; }
  }

  /* < 480px: pub year column narrower */
  @media (max-width: 479px) {
    .pub { grid-template-columns: 2.75rem 1fr; gap: var(--space-xs); }
  }
</style>
