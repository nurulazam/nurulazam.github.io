---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";

// Phase 1 is static — contact is a plain mailto, no form backend.
const EMAIL = "nurul_azam@outlook.com";
---
<BaseLayout title="Contact" description="Get in touch with Dr. Nurul Azam about collaboration in quantum-materials synthesis, characterisation, or scientific software.">
  <div class="container contact">
    <Breadcrumbs crumbs={[{ label: "Home", href: "/" }, { label: "Contact" }]} />

    <header class="contact__head">
      <h1>Get in touch</h1>
      <p class="lede">
        Interested in collaborating — on materials synthesis, momentum-microscopy
        or Raman characterisation, or scientific software? Email is the best way
        to reach me.
      </p>
    </header>

    <p class="contact__email">
      <a href={`mailto:${EMAIL}`}>{EMAIL}</a>
    </p>

    <p class="contact__note ui">
      I read everything and reply when I can. Other links (Scholar, ORCID,
      GitHub, LinkedIn) are in the footer.
    </p>
  </div>
</BaseLayout>

<style>
  .contact { padding-block: var(--space-xl); }
  .contact__head { max-width: var(--measure); margin-block: var(--space-m) var(--space-l); }
  .contact__head h1 { margin-top: var(--space-2xs); }
  .lede { font-size: var(--step-1); color: var(--ink-soft); margin: 0; }

  .contact__email { margin: 0 0 var(--space-s); }
  .contact__email a {
    font-family: var(--font-display);
    font-size: var(--step-2);
    color: var(--accent-ink);
    text-decoration: none;
    text-underline-offset: 0.15em;
    word-break: break-word;
  }
  .contact__email a:hover { text-decoration: underline; }

  .contact__note { max-width: var(--measure); font-size: var(--step--1); color: var(--ink-soft); margin: 0; }
</style>
