---
import { SITE, SOCIALS } from "../config/site";
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container inner">
    <div>
      <p class="name">{SITE.title}</p>
      <p class="tag ui">{SITE.tagline}</p>
    </div>
    <nav aria-label="Elsewhere" class="links">
      <ul>
        {SOCIALS.map((s) => (
          <li><a href={s.href} rel="me noopener" target="_blank">{s.label}</a></li>
        ))}
        <li><a href="/rss.xml">RSS</a></li>
      </ul>
    </nav>
  </div>
  <div class="container copyright ui">© {year} {SITE.author}</div>
</footer>

<style>
  .site-footer { border-top: 1px solid var(--rule); margin-top: var(--space-2xl); padding-block: var(--space-xl) var(--space-l); }
  .inner { display: flex; flex-wrap: wrap; gap: var(--space-l); justify-content: space-between; }
  .name { font-family: var(--font-display); font-size: var(--step-1); margin: 0; }
  .tag { color: var(--ink-soft); margin: var(--space-3xs) 0 0; font-size: var(--step--1); }
  .links ul { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: var(--space-m); }
  .links a { font-family: var(--font-ui); font-size: var(--step--1); color: var(--ink-soft); text-decoration: none; }
  .links a:hover { color: var(--ink); }
  .copyright { color: var(--ink-soft); font-size: var(--step--1); margin-top: var(--space-l); }
</style>
