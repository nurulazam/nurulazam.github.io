---
import { SITE, NAV, PRIMARY_CTA } from "../config/site";
import ThemeToggle from "./ThemeToggle.astro";
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== "/" && path.startsWith(href));
---
<header class="site-header">
  <div class="container bar">
    <a class="brand" href="/">{SITE.title}</a>

    <button class="menu-toggle ui" aria-expanded="false" aria-controls="primary-nav">
      <span class="menu-toggle__bars" aria-hidden="true"></span>
      Menu
    </button>

    <nav id="primary-nav" class="nav" aria-label="Primary">
      <ul>
        {NAV.map((item) => (
          <li>
            <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      <a class="cta" href={PRIMARY_CTA.href}>{PRIMARY_CTA.label}</a>
      <ThemeToggle />
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--rule);
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(8px);
    position: sticky; top: 0; z-index: 50;
  }
  .bar { display: flex; align-items: center; gap: var(--space-m); padding-block: var(--space-s); }
  .brand {
    font-family: var(--font-display);
    font-size: var(--step-1); font-weight: 560; letter-spacing: -0.01em;
    color: var(--ink); text-decoration: none; margin-right: auto;
  }
  .nav { display: flex; align-items: center; gap: var(--space-m); }
  .nav ul { display: flex; gap: var(--space-m); list-style: none; margin: 0; padding: 0; }
  .nav a {
    font-family: var(--font-ui); font-size: var(--step--1);
    color: var(--ink-soft); text-decoration: none; letter-spacing: 0.01em;
  }
  .nav a:hover, .nav a[aria-current="page"] { color: var(--ink); }
  .cta {
    font-family: var(--font-ui); font-size: var(--step--1); font-weight: 500;
    color: var(--surface); background: var(--accent);
    padding: var(--space-2xs) var(--space-s); border-radius: var(--radius);
    text-decoration: none;
  }
  .cta:hover { filter: brightness(1.05); }

  .menu-toggle {
    display: none; align-items: center; gap: var(--space-2xs);
    background: none; border: 1px solid var(--rule); border-radius: var(--radius);
    color: var(--ink); padding: var(--space-2xs) var(--space-xs); cursor: pointer;
    font-size: var(--step--1);
  }
  .menu-toggle__bars,
  .menu-toggle__bars::before,
  .menu-toggle__bars::after {
    content: ""; display: block; width: 16px; height: 1.5px; background: var(--ink); position: relative;
  }
  .menu-toggle__bars::before { position: absolute; top: -5px; }
  .menu-toggle__bars::after  { position: absolute; top: 5px; }

  @media (max-width: 820px) {
    .menu-toggle { display: inline-flex; }
    .nav {
      position: absolute; left: 0; right: 0; top: 100%;
      flex-direction: column; align-items: flex-start; gap: var(--space-s);
      background: var(--surface); border-bottom: 1px solid var(--rule);
      padding: var(--space-m); box-shadow: var(--shadow);
      display: none;
    }
    .nav[data-open="true"] { display: flex; }
    .nav ul { flex-direction: column; gap: var(--space-s); }
  }
</style>

<script>
  const toggle = document.querySelector(".menu-toggle");
  const nav = document.getElementById("primary-nav");
  toggle?.addEventListener("click", () => {
    const open = nav?.getAttribute("data-open") === "true";
    nav?.setAttribute("data-open", String(!open));
    toggle.setAttribute("aria-expanded", String(!open));
  });
</script>
