---
import { SITE, NAV, PRIMARY_CTA } from "../config/site";
import ThemeToggle from "./ThemeToggle.astro";
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== "/" && path.startsWith(href));
---
<header class="site-header">
  <div class="container bar">
    <a class="brand" href="/">{SITE.title}</a>

    <button
      class="menu-toggle ui"
      type="button"
      aria-expanded="false"
      aria-controls="primary-nav"
      aria-label="Open navigation menu"
    >
      <span class="menu-toggle__bars" aria-hidden="true"></span>
      Menu
    </button>

    <nav id="primary-nav" class="nav" aria-label="Primary">
      <ul>
        {NAV.map((item) => (
          <li>
            <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      <a class="cta" href={PRIMARY_CTA.href}>{PRIMARY_CTA.label}</a>
      <ThemeToggle />
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--rule);
    background: var(--bg); /* fallback for color-mix */
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    position: sticky; top: 0; z-index: 50;
  }
  .bar {
    display: flex; align-items: center; gap: var(--space-m);
    padding-block: var(--space-s);
  }
  .brand {
    font-family: var(--font-display);
    font-size: var(--step-1); font-weight: 560; letter-spacing: -0.01em;
    color: var(--ink); text-decoration: none; margin-right: auto;
  }
  .brand:hover { color: var(--accent-ink); }

  /* ── Desktop nav ── */
  .nav { display: flex; align-items: center; gap: var(--space-m); }
  .nav ul { display: flex; gap: var(--space-m); list-style: none; margin: 0; padding: 0; }
  .nav a {
    font-family: var(--font-ui); font-size: var(--step--1);
    color: var(--ink-soft); text-decoration: none; letter-spacing: 0.01em;
    transition: color var(--transition-base);
  }
  .nav a:hover,
  .nav a[aria-current="page"] { color: var(--ink); }
  .nav a[aria-current="page"] { font-weight: 500; }

  /* ── Primary CTA ── */
  .cta {
    font-family: var(--font-ui); font-size: var(--step--1); font-weight: 500;
    color: var(--bg); background: var(--accent);
    padding: var(--space-2xs) var(--space-s);
    border-radius: var(--radius); text-decoration: none;
    display: inline-flex; align-items: center; min-height: 44px;
    transition: opacity var(--transition-base);
  }
  .cta:hover { opacity: 0.88; }
  .cta:focus-visible {
    outline: var(--focus); outline-offset: 3px;
    border-radius: var(--radius);
  }

  /* ── Mobile toggle ── */
  .menu-toggle {
    display: none; align-items: center; gap: var(--space-2xs);
    background: none; border: 1px solid var(--rule); border-radius: var(--radius);
    color: var(--ink); padding: var(--space-2xs) var(--space-xs);
    cursor: pointer; font-size: var(--step--1); min-height: 44px;
    transition: border-color var(--transition-base);
  }
  .menu-toggle:hover { border-color: var(--ink-soft); }
  .menu-toggle__bars,
  .menu-toggle__bars::before,
  .menu-toggle__bars::after {
    content: ""; display: block;
    width: 16px; height: 1.5px;
    background: currentColor; position: relative;
  }
  .menu-toggle__bars { position: relative; }
  .menu-toggle__bars::before { position: absolute; top: -5px; }
  .menu-toggle__bars::after  { position: absolute; top:  5px; }

  /* ── Responsive: ≤ 820px ── */
  @media (max-width: 820px) {
    .menu-toggle { display: inline-flex; }
    .nav {
      position: absolute; left: 0; right: 0; top: 100%;
      flex-direction: column; align-items: flex-start; gap: var(--space-s);
      background: var(--surface); border-bottom: 1px solid var(--rule);
      padding: var(--space-m); box-shadow: var(--shadow);
      /* hidden by default */
      display: none;
    }
    .nav[data-open="true"] { display: flex; }
    .nav ul { flex-direction: column; gap: var(--space-s); width: 100%; }
    .nav ul a { font-size: var(--step-0); }
    .cta { width: 100%; justify-content: center; }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(".menu-toggle");
  const nav    = document.getElementById("primary-nav");

  function openMenu() {
    nav?.setAttribute("data-open", "true");
    toggle?.setAttribute("aria-expanded", "true");
    toggle?.setAttribute("aria-label", "Close navigation menu");
  }

  function closeMenu() {
    nav?.setAttribute("data-open", "false");
    toggle?.setAttribute("aria-expanded", "false");
    toggle?.setAttribute("aria-label", "Open navigation menu");
  }

  toggle?.addEventListener("click", () => {
    nav?.getAttribute("data-open") === "true" ? closeMenu() : openMenu();
  });

  // Close on Escape — return focus to the toggle (WCAG keyboard nav)
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && nav?.getAttribute("data-open") === "true") {
      closeMenu();
      toggle?.focus();
    }
  });

  // Close when clicking outside the header
  document.addEventListener("click", (e) => {
    const header = document.querySelector(".site-header");
    if (
      header &&
      !header.contains(e.target as Node) &&
      nav?.getAttribute("data-open") === "true"
    ) {
      closeMenu();
    }
  });
</script>
