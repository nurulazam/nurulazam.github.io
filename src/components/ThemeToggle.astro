---
// Light/dark toggle. Persists choice; respects system default on first visit.
---
<button class="theme-toggle ui" type="button" aria-label="Toggle colour theme" title="Toggle theme">
  <span aria-hidden="true" class="theme-toggle__icon">◑</span>
</button>

<style>
  .theme-toggle {
    background: none; border: 1px solid var(--rule); border-radius: var(--radius);
    color: var(--ink); width: 2rem; height: 2rem; cursor: pointer;
    display: inline-grid; place-items: center; font-size: 1rem;
  }
  .theme-toggle:hover { border-color: var(--ink-soft); }
</style>

<script>
  const btn = document.querySelector(".theme-toggle");
  btn?.addEventListener("click", () => {
    const root = document.documentElement;
    const next = root.dataset.theme === "dark" ? "light" : "dark";
    if (next === "dark") root.dataset.theme = "dark";
    else delete root.dataset.theme;
    localStorage.setItem("theme", next);
  });
</script>
